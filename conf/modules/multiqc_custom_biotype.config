process {
    withName: 'CUSTOM_MULTIQCCUSTOMBIOTYPE' {
        publishDir = [
            path: { "${params.outdir}/${task.ext.publish_prefix}${params.aligner}/featurecounts" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}
