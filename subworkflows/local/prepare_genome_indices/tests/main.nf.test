                pseudo_aligner           = 'salmon'
                skip_gtf_filter          = false
                skip_bbsplit             = true
                ribo_removal_tool        = null
                skip_alignment           = false
                skip_pseudo_alignment    = false
                use_sentieon_star        = false
                use_parabricks_star      = false

                input[0]  = PREPARE_GENOME_REFERENCES.out.fasta_fai  // fasta_fai channel
                input[1]  = PREPARE_GENOME_REFERENCES.out.gtf  // gtf channel
                input[2]  = PREPARE_GENOME_REFERENCES.out.transcript_fasta  // transcript_fasta channel
                input[3]  = PREPARE_GENOME_REFERENCES.out.rrna_fastas  // rrna_fastas channel
                input[4]  = true  // fasta_provided
                input[5]  = null
                input[6]  = file(params.pipelines_testdata_base_path + 'reference/bbsplit_fasta_list.txt', checkIfExists: true)
                input[7]  = null
                input[8]  = file(params.pipelines_testdata_base_path + 'reference/rsem.tar.gz', checkIfExists: true)
                input[9]  = file(params.pipelines_testdata_base_path + 'reference/salmon.tar.gz', checkIfExists: true)
                input[10] = null
                input[11] = file(params.pipelines_testdata_base_path + 'reference/hisat2.tar.gz', checkIfExists: true)
                input[12] = null
                input[13] = null
                input[14] = null
                input[15] = aligner
                input[16] = pseudo_aligner
                input[17] = skip_bbsplit
                input[18] = ribo_removal_tool
                input[19] = skip_alignment
                input[20] = skip_pseudo_alignment
                input[21] = use_sentieon_star
                input[22] = use_parabricks_star
                input[23] = false  // star_index_legacy
                """
            }
        }

        then {
            assert workflow.success
        }

        cleanup {
            if (System.getenv("NFT_PROFILE")?.contains("docker")) {
                "docker system prune -a -f --volumes".execute()
            }
            new File("${launchDir}").deleteDir()
        }
    }

    test("skip_alignment = true - stub") {

        options "-stub"

        setup {
            run("PREPARE_GENOME_REFERENCES") {
                script "../../prepare_genome_references/main.nf"
                options "-stub"
                workflow {
                    """
                    gencode                  = false
                    featurecounts_group_type = 'gene_biotype'
                    aligner                  = 'star_salmon'
                    pseudo_aligner           = 'salmon'
                    skip_gtf_filter          = false
                    skip_bbsplit             = false
                    ribo_removal_tool        = null
                    skip_alignment           = true
                    skip_pseudo_alignment    = false
                    use_sentieon_star        = false
                    use_parabricks_star      = false

                    input[0]  = file(params.pipelines_testdata_base_path + 'reference/genome.fasta', checkIfExists: true)
                    input[1]  = file(params.pipelines_testdata_base_path + 'reference/genes_with_empty_tid.gtf', checkIfExists: true)
                    input[2]  = file(params.pipelines_testdata_base_path + 'reference/genes.gff', checkIfExists: true)
                    input[3]  = file(params.pipelines_testdata_base_path + 'reference/gfp.fa', checkIfExists: true)
                    input[4]  = file(params.pipelines_testdata_base_path + 'reference/transcriptome.fasta', checkIfExists: true)
                    input[5]  = null
                    input[6]  = null
                    input[7]  = null  // kraken_db
                    input[8]  = gencode
                    input[9]  = false
                    input[10] = featurecounts_group_type
                    input[11] = aligner
                    input[12] = pseudo_aligner
                    input[13] = skip_gtf_filter
                    input[14] = ribo_removal_tool
                    input[15] = skip_alignment
                    input[16] = skip_pseudo_alignment
                    input[17] = use_sentieon_star
                    input[18] = null  // contaminant_screening
                    input[19] = false  // prokaryotic
                    """
                }
            }
        }

        when {
            workflow {
                """
                gencode                  = false
                featurecounts_group_type = 'gene_biotype'
                aligner                  = 'star_salmon'
                pseudo_aligner           = 'salmon'
                skip_gtf_filter          = false
                skip_bbsplit             = false
                ribo_removal_tool        = null
                skip_alignment           = true
                skip_pseudo_alignment    = false
                use_sentieon_star        = false
                use_parabricks_star      = false

                input[0]  = PREPARE_GENOME_REFERENCES.out.fasta_fai  // fasta_fai channel
                input[1]  = PREPARE_GENOME_REFERENCES.out.gtf  // gtf channel
                input[2]  = PREPARE_GENOME_REFERENCES.out.transcript_fasta  // transcript_fasta channel
                input[3]  = PREPARE_GENOME_REFERENCES.out.rrna_fastas  // rrna_fastas channel
                input[4]  = true  // fasta_provided
                input[5]  = null
                input[6]  = file(params.pipelines_testdata_base_path + 'reference/bbsplit_fasta_list.txt', checkIfExists: true)
                input[7]  = null
                input[8]  = file(params.pipelines_testdata_base_path + 'reference/rsem.tar.gz', checkIfExists: true)
                input[9]  = file(params.pipelines_testdata_base_path + 'reference/salmon.tar.gz', checkIfExists: true)
                input[10] = null
                input[11] = file(params.pipelines_testdata_base_path + 'reference/hisat2.tar.gz', checkIfExists: true)
                input[12] = null
                input[13] = null
                input[14] = null
                input[15] = aligner
                input[16] = pseudo_aligner
                input[17] = skip_bbsplit
                input[18] = ribo_removal_tool
                input[19] = skip_alignment
                input[20] = skip_pseudo_alignment
                input[21] = use_sentieon_star
                input[22] = use_parabricks_star
                input[23] = false  // star_index_legacy
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.hisat2_index.collect { path -> file(path).listFiles().collect { f -> f.getName() }.sort().toString() },
                    workflow.out.bowtie2_index.collect { path -> file(path).listFiles().collect { f -> f.getName() }.sort().toString() },
                    workflow.out.kallisto_index.collect { meta, path -> file(path).listFiles().collect { f -> f.getName() }.sort().toString() },
                    workflow.out.rsem_index.collect { path -> file(path).listFiles().collect { f -> f.getName() }.sort().toString() },
                    workflow.out.salmon_index.collect { path -> file(path).listFiles().collect { f -> f.getName() }.sort().toString() },
                    workflow.out.sortmerna_index,
                    workflow.out.splicesites.collect { p -> file(p).exists() ? [ file(p).name, path(p).md5 ] : p.toString() },
                    workflow.out.star_index.collect { path -> file(path).listFiles().collect { f -> f.getName() }.sort().toString() }
                ).match() }
            )
        }

        cleanup {
            if (System.getenv("NFT_PROFILE")?.contains("docker")) {
                "docker system prune -a -f --volumes".execute()
            }
            new File("${launchDir}").deleteDir()
        }
    }

