                    input[15] = skip_alignment
                    input[16] = skip_pseudo_alignment
                    input[17] = use_sentieon_star
                    input[18] = null  // contaminant_screening
                    input[19] = false  // prokaryotic
                    """
                }
            }
        }

        when {
            workflow {
                """
                gencode                  = false
                featurecounts_group_type = 'gene_biotype'
                aligner                  = 'star_salmon'
                pseudo_aligner           = 'salmon'
                skip_gtf_filter          = false
                skip_bbsplit             = false
