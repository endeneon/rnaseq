                    input[10] = featurecounts_group_type
                    input[11] = aligner
                    input[12] = pseudo_aligner
                    input[13] = skip_gtf_filter
                    input[14] = ribo_removal_tool
                    input[15] = skip_alignment
                    input[16] = skip_pseudo_alignment
                    input[17] = use_sentieon_star
                    input[18] = null  // contaminant_screening
